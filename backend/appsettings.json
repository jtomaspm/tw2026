{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5080"
      }
    }
  },
  "SnipeScheduler": {
    "WakeLeadMilliseconds": 1500,
    "MaximumWakeLeadMilliseconds": 10000,
    "FinalSpinMilliseconds": 15,
    "LateToleranceMilliseconds": 50,
    "ReconnectWindowMilliseconds": 15000,
    "MaximumJobs": 256,
    "JobExpiryMilliseconds": 60000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SnipeScheduler": "Information"
    }
  },
  "AllowedHosts": "*"
}
